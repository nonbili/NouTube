<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>jp.nonbili.noutube</id>

  <name>NouTube</name>
  <summary>YouTube and YouTube Music in a single app</summary>

  <developer id="jp.nonbili">
    <name>Nonbili Inc.</name>
  </developer>

  <metadata_license>CC-BY-SA-4.0</metadata_license>
  <project_license>AGPL-3.0-or-later</project_license>

  <branding>
    <color type="primary" scheme_preference="light">#99c1f1</color>
    <color type="primary" scheme_preference="dark">#a599a5</color>
  </branding>

  <description>
    <ul>
      <li>Manage video/music library without login</li>
      <li>Manage watch history without login</li>
      <li>No ads</li>
      <li>Hide shorts</li>
      <li>Sponsor block</li>
    </ul>
  </description>

  <keywords>
    <keyword>youtube</keyword>
    <keyword>youtube-music</keyword>
    <keyword>yt</keyword>
    <keyword>yt-music</keyword>
  </keywords>

  <launchable type="desktop-id">jp.nonbili.noutube.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/nonbili/NouTube-Desktop/942f89c4def0dabaa89fa0e08cbe3942bcb76926/metadata/screenshots/1.png</image>
      <caption>YouTube Music</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/nonbili/NouTube-Desktop/942f89c4def0dabaa89fa0e08cbe3942bcb76926/metadata/screenshots/2.png</image>
      <caption>YouTube</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/nonbili/NouTube-Desktop/942f89c4def0dabaa89fa0e08cbe3942bcb76926/metadata/screenshots/3.png</image>
      <caption>YouTube Channel Feeds</caption>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/nonbili/NouTube-Desktop</url>
  <url type="vcs-browser">https://github.com/nonbili/NouTube</url>
  <url type="bugtracker">https://github.com/nonbili/NouTube/issues</url>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.2.4" date="2026-03-10">
      <description>
        <ul>
          <li>Add share menu to bookmark/history/feed item</li>
          <li>Add German and Portuguese translations</li>
          <li>Improve library and feed loading performance</li>
          <li>Improve importing process</li>
        </ul>
      </description>
    </release>
    <release version="0.2.3" date="2026-02-20">
      <description>
        <ul>
          <li>Fix importing from yt takeout on Windows</li>
        </ul>
      </description>
    </release>
    <release version="0.2.2" date="2026-02-19">
      <description>
        <ul>
          <li>Fix importing from yt takeout</li>
        </ul>
      </description>
    </release>
    <release version="0.2.1" date="2026-02-19">
      <description>
        <ul>
          <li>Support customize user agent</li>
          <li>Support injecting cookies.txt</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-02-08">
      <description>
        <ul>
          <li>Fix ad blocking</li>
          <li>Support injecting cookie to fix login</li>
          <li>Support restoring progress from History panel</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
